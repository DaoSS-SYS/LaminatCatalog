
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}


model Color {
  id             String   @id @default(cuid())
  name           String
  productType    String   @default("laminat")
  sku            String?
  brand          String?
  collection     String?
  tone           String?
  wearClass      Int?
  thicknessMm    Int?
  plankSize      String?
  bevelType      String?
  waterResistant Boolean  @default(false)
  surfaceType    String?
  pricePerM2     Float?
  inStock        Boolean  @default(true)
  imagesJson     String   @default("[]")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([productType])
  @@index([tone])
}
